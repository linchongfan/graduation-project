@startuml 数据流图
title 混合蚁群算法数据流

skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 11
skinparam activityBackgroundColor #E8F4FD
skinparam activityBorderColor #4A90D9

|#LightBlue|输入数据|
start
:城市坐标列表;
note right
  cities = [(x1,y1), (x2,y2), ...]
end note

:算法参数;
note right
  • ant_count, max_iter
  • α, β, ρ, Q
  • crossover_rate, mutation_rate
  • elite_ratio
end note

|#E8F8E8|数据处理|
:计算距离矩阵;
note right
  D[i][j] = Euclidean(i, j)
  大小: n × n
end note

:初始化信息素矩阵;
note right
  τ[i][j] = 1.0
  大小: n × n
end note

|#FFFACD|算法执行|
:蚁群构建路径;
note right
  输出: all_paths[n_ant]
  每条路径: [c1, c2, ..., cn, c1]
end note

:计算路径距离;
note right
  输出: all_distances[n_ant]
  每个距离: float
end note

#LightGreen:遗传算法增强;
note right
  输入: all_paths, all_distances
  输出: new_paths, new_distances
  操作: 选择→交叉→变异
end note

#LightYellow:2-opt优化;
note right
  输入: 精英路径
  输出: 优化后路径
  操作: 反转路径片段
end note

:更新全局最优;
note right
  best_path = 当前最优路径
  best_distance = 当前最优距离
end note

#LightCoral:信息素更新;
note right
  输入: all_paths, all_distances
  输出: 更新后的信息素矩阵
  操作: 挥发 + 强化
end note

|#FFE4E1|输出数据|
:收敛数据;
note right
  • iteration_best_distances[]
  • alpha_history[]
  • beta_history[]
end note

:最终结果;
note right
  AlgorithmResult {
    best_path: List[int]
    best_distance: float
    running_time: float
    convergence_iteration: int
    iteration_best_distances: List[float]
    first_iteration_distance: float
    last_decrease_iteration: int
  }
end note

:可视化输出;
note right
  左图: 最优路径图
  右图: 收敛曲线
end note

:文件导出;
note right
  • JSON格式
  • TXT格式
  • CSV格式
end note

stop

@enduml
