@startuml 2-opt局部搜索详细流程图
title 2-opt 局部搜索详细流程

skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 11
skinparam activityBackgroundColor #FFFACD
skinparam activityBorderColor #DAA520
skinparam activityDiamondBackgroundColor #FFE4B5

start

:输入：待优化的路径;
note right
  path = [0, 1, 2, 3, 4, 5, 6, 0]
  distance = 28.5
end note

:best_path = path;
:best_distance = 计算距离;
:improved = True;

repeat

  :improved = False;

  :i = 1;

  while (i < n-2?) is (是)

    :j = i+1;

    while (j < n-1?) is (是)

      :获取边对;
      note right
        A = path[i-1]
        B = path[i]
        C = path[j]
        D = path[j+1]

        当前边: A→B 和 C→D
      end note

      :计算距离变化;
      note right
        old_dist = dist(A,B) + dist(C,D)
        new_dist = dist(A,C) + dist(B,D)
        delta = new_dist - old_dist
      end note

      if (delta < -1e-10?) then (是)
        #LightGreen:执行2-opt交换;
        note right
          **反转 path[i:j+1]**

          交换前：
          ... → A → B → X → Y → Z → C → D → ...

          交换后：
          ... → A → C → Z → Y → X → B → D → ...

          距离减少：|delta|
        end note

        :best_distance += delta;
        :improved = True;

        break

      else (否)
      endif

      :j++;

    endwhile

    if (improved?) then (是)
      break
    endif

    :i++;

  endwhile

repeat while (improved?) is (是)
->否;

:输出优化后的路径;
note right
  最终路径：[0, 5, 4, 3, 2, 1, 6, 0]
  最终距离：25.8
  改善幅度：2.7 (9.5%)
end note

stop

@enduml
