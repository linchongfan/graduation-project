@startuml
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Microsoft YaHei
skinparam activity {
  BackgroundColor #F8FBFF
  BorderColor #4A6FA5
  DiamondBackgroundColor #FFF7E6
  DiamondBorderColor #C98A2E
  StartColor #6CBF84
  EndColor #D96C6C
  BarColor #4A6FA5
}

title 蚁群算法求解 TSP 问题程序流程图

start
:运行 `main.py`;
:创建 Tk 根窗口;
:初始化 `AntColonyGUI`;
:显示参数输入区、按钮区、结果区和画布;

while (程序是否继续运行?) is (是)
  :等待用户操作;

  if (是否点击“生成地图”?) then (是)
    :读取城市数量;
    if (城市数量 < 2?) then (是)
      :弹出错误提示;
    else (否)
      :调用 `generate_cities(n_cities)`;
      :保存城市坐标到 `self.cities`;
      :绘制城市分布散点图;
      :提示“可继续运行算法”;
    endif
  else (否)
  endif

  if (是否点击“运行算法”?) then (是)
    :读取城市数量、蚂蚁数量、\nalpha、beta、rho、q、max_iter;
    if (城市数量 < 2\n或蚂蚁数量 < 1?) then (是)
      :弹出错误提示;
    else (否)
      if (`self.cities` 为空\n或城市数量已变化?) then (是)
        :重新生成城市坐标;
      else (否)
        :复用当前城市地图;
      endif

      :初始化 `AntColonyTSP`;
      :计算距离矩阵;
      :初始化信息素矩阵;

      repeat
        :为每只蚂蚁构造路径;
        repeat
          :根据信息素和启发函数\n选择下一城市;
        repeat while (是否仍有未访问城市?) is (是)

        :回到起点形成闭环;
        :计算当前路径总距离;
        if (当前路径优于全局最优?) then (是)
          :更新全局最优路径与最优距离;
        else (否)
        endif

        :完成本轮全部蚂蚁后\n挥发并强化信息素;
        :记录本轮最优距离;
      repeat while (是否达到最大迭代次数?) is (否)

      :计算运行时间;
      :计算收敛迭代次数;
      :返回结果字典;
      :更新结果文本框;
      :绘制最优路径图;
      :绘制收敛曲线;
      :刷新画布显示;
    endif
  else (否)
  endif
endwhile (否)

stop

@enduml
